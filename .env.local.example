# ─────────────────────────────────────────────
# Supabase (required)
# ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# Keep this server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# AI / Content Generation (optional — can also be set per-user in Settings)
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# ─────────────────────────────────────────────
# Email delivery (optional — can be set per-user in Settings)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key-here

# ─────────────────────────────────────────────
# SMS (optional — can be set per-user in Settings)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─────────────────────────────────────────────
# Lead sourcing (optional — can be set per-user in Settings)
# ─────────────────────────────────────────────
OUTSCRAPER_API_KEY=your-outscraper-key-here
BRAVE_API_KEY=your-brave-search-key-here

# ─────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────
# Set to true to use fake prospect data (skips all external API calls)
NEXT_PUBLIC_USE_MOCK_DATA=false
